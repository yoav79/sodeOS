# ==============================================================================
# TEMPLATE DE CONFIGURACIÓN DE PRODUCCIÓN - sodeOS (cerebro-empresarial)
# ==============================================================================
# INSTRUCCIONES: Copiar este archivo a .env.local en el servidor y rellenar los
# valores reales. NUNCA agregues secretos reales a este archivo ni lo comitees.

# Supabase (Configuraciones para integración futura, si aplica)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-production-placeholder
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-production-placeholder

# PostgreSQL - Base de datos de producción (Prisma)
# IMPORTANTE: Asegurarse de usar contraseñas robustas y que el puerto no sea accesible desde el internet público.
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@DB_PRIVATE_HOST:5432/DB_NAME?schema=public"

# Cloudflare R2 Storage (Almacenamiento de archivos privados)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-production-bucket-name
R2_ACCESS_KEY_ID=your-production-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-production-r2-secret-access-key
R2_REGION=auto

# Proveedor de Inteligencia Artificial (OpenAI)
AI_PROVIDER=openai
AI_PROVIDER_API_KEY=your-openai-api-key-production
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2000

# Serper API (Motor de búsqueda web para el agente IA)
SERPER_API_KEY=your-serper-api-key-production

# Código privado de acceso requerido para el registro de nuevos usuarios
REGISTRATION_ACCESS_CODE="change-me"

