# Supabase Configuration (Future integration)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-placeholder
NEXT_PUBLIC_SUPABASE_anon_key=your-supabase-anon-key-placeholder

# PostgreSQL/Supabase Database connection string (for Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Cloudflare R2 Storage Configuration
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name-placeholder
R2_ACCESS_KEY_ID=your-r2-access-key-id-placeholder
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key-placeholder
R2_REGION=auto

# AI Assistant Configuration
AI_PROVIDER=openai
AI_PROVIDER_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2000

# AI Serper Configuration
SERPER_API_KEY=