datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum BrainVisibility {
  private
  invited_only
  company
}

enum BrainRole {
  owner
  editor
  reader
}

enum OrgRole {
  org_owner
  org_member
}

enum OrganizationPlan {
  free
  pro
  enterprise
}

enum NodeStatus {
  draft
  active
  needs_review
  archived
}

enum TemplateType {
  page
  structure
}

enum AttachmentExtractionStatus {
  pending
  processing
  done
  failed
  unsupported
}

model Organization {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String           @unique
  plan      OrganizationPlan @default(free)
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  // Relations
  memberships OrganizationMembership[]
  brains      Brain[]
  usageRecords UsageRecord[]

  @@index([slug])
  @@map("organizations")
}

model OrganizationMembership {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           OrgRole  @default(org_member)
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, organizationId])
  @@map("organization_memberships")
}

model User {
  id         String   @id @db.Uuid
  email      String   @unique
  name       String
  avatarUrl  String?  @map("avatar_url")
  phone      String?
  company    String?
  department String?
  jobTitle   String?  @map("job_title")
  isSysadmin Boolean  @default(false) @map("is_sysadmin")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  createdBrains      Brain[]                  @relation("CreatedBrains")
  memberships        BrainMember[]
  orgMemberships     OrganizationMembership[]
  createdTemplates   Template[]               @relation("CreatedTemplates")
  updatedTemplates   Template[]               @relation("UpdatedTemplates")
  ownedNodes         Node[]                   @relation("OwnedNodes")
  responsibleNodes   Node[]                   @relation("ResponsibleNodes")
  createdNodes       Node[]                   @relation("CreatedNodes")
  updatedNodes       Node[]                   @relation("UpdatedNodes")
  lockedNodes        Node[]                   @relation("LockedNodes")
  savedVersions      NodeVersion[]
  credentials        UserCredential?
  sessions           Session[]
  uploadedAttachments NodeAttachment[]        @relation("UploadedAttachments")
  usageRecords       UsageRecord[]

  @@map("users")
}

model Brain {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  visibility     BrainVisibility @default(private)
  organizationId String          @map("organization_id") @db.Uuid
  createdBy      String          @map("created_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  creator      User         @relation("CreatedBrains", fields: [createdBy], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  members      BrainMember[]
  templates    Template[]
  nodes        Node[]
  tags         Tag[]
  attachments  NodeAttachment[]
  attachmentChunks NodeAttachmentChunk[]
  usageRecords     UsageRecord[]

  @@index([organizationId])
  @@map("brains")
}

model BrainMember {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brainId   String    @map("brain_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      BrainRole @default(reader)
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  brain Brain @relation(fields: [brainId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([brainId, userId])
  @@index([userId, brainId])
  @@map("brain_members")
}

model Template {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brainId      String       @map("brain_id") @db.Uuid
  name         String
  description  String?
  templateType TemplateType @map("template_type")
  schemaJson   Json         @map("schema_json")
  createdBy    String       @map("created_by") @db.Uuid
  updatedBy    String?      @map("updated_by") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  brain   Brain  @relation(fields: [brainId], references: [id], onDelete: Cascade)
  creator User   @relation("CreatedTemplates", fields: [createdBy], references: [id], onDelete: Restrict)
  updater User?  @relation("UpdatedTemplates", fields: [updatedBy], references: [id], onDelete: SetNull)
  nodes   Node[]

  @@map("templates")
}

model Node {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brainId           String     @map("brain_id") @db.Uuid
  parentId          String?    @map("parent_id") @db.Uuid
  templateId        String?    @map("template_id") @db.Uuid
  title             String
  slug              String
  contentMarkdown   String     @default("") @map("content_markdown")
  status            NodeStatus @default(draft)
  description       String?
  category          String?
  ownerUserId       String     @map("owner_user_id") @db.Uuid
  responsibleUserId String     @map("responsible_user_id") @db.Uuid
  position          Int        @default(0)
  lockedBy          String?    @map("locked_by") @db.Uuid
  lockedAt          DateTime?  @map("locked_at")
  createdBy         String     @map("created_by") @db.Uuid
  updatedBy         String     @map("updated_by") @db.Uuid
  reviewedAt        DateTime?  @map("reviewed_at")
  nextReviewAt      DateTime?  @map("next_review_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  deletedAt         DateTime?  @map("deleted_at")

  // Relations
  brain       Brain         @relation(fields: [brainId], references: [id], onDelete: Cascade)
  parent      Node?         @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    Node[]        @relation("NodeHierarchy")
  template    Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  owner       User          @relation("OwnedNodes", fields: [ownerUserId], references: [id], onDelete: Restrict)
  responsible User          @relation("ResponsibleNodes", fields: [responsibleUserId], references: [id], onDelete: Restrict)
  creator     User          @relation("CreatedNodes", fields: [createdBy], references: [id], onDelete: Restrict)
  updater     User          @relation("UpdatedNodes", fields: [updatedBy], references: [id], onDelete: Restrict)
  locker      User?         @relation("LockedNodes", fields: [lockedBy], references: [id], onDelete: SetNull)
  versions    NodeVersion[]
  nodeTags    NodeTag[]
  attachments NodeAttachment[]
  attachmentChunks NodeAttachmentChunk[]
  usageRecords     UsageRecord[]

  @@unique([brainId, parentId, slug])
  @@index([brainId, parentId, position])
  @@index([brainId, slug])
  @@index([lockedBy])
  @@map("nodes")
}

model NodeVersion {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId          String     @map("node_id") @db.Uuid
  title           String
  contentMarkdown String     @map("content_markdown")
  status          NodeStatus
  savedBy         String     @map("saved_by") @db.Uuid
  changeNote      String?    @map("change_note")
  createdAt       DateTime   @default(now()) @map("created_at")

  // Relations
  node  Node @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  saver User @relation(fields: [savedBy], references: [id], onDelete: Restrict)

  @@index([nodeId, createdAt(sort: Desc)])
  @@map("node_versions")
}

model Tag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brainId   String   @map("brain_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  brain    Brain     @relation(fields: [brainId], references: [id], onDelete: Cascade)
  nodeTags NodeTag[]

  @@unique([brainId, name])
  @@map("tags")
}

model NodeTag {
  nodeId String @map("node_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  // Relations
  node Node @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([nodeId, tagId])
  @@map("node_tags")
}

model UserCredential {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credentials")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  sessionToken String   @unique @map("session_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
  @@map("sessions")
}

model NodeAttachment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId       String   @map("node_id") @db.Uuid
  brainId      String   @map("brain_id") @db.Uuid
  uploadedById String   @map("uploaded_by_id") @db.Uuid
  r2Key        String   @unique @map("r2_key")
  filename     String
  contentType  String   @map("content_type")
  size         Int
  createdAt    DateTime @default(now()) @map("created_at")

  // Extraction status fields
  extractionStatus AttachmentExtractionStatus @default(pending) @map("extraction_status")
  extractionError  String?                    @map("extraction_error")

  // Relations
  node       Node                  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  brain      Brain                 @relation(fields: [brainId], references: [id], onDelete: Cascade)
  uploadedBy User                  @relation("UploadedAttachments", fields: [uploadedById], references: [id], onDelete: Restrict)
  chunks     NodeAttachmentChunk[]

  @@index([nodeId, createdAt(sort: Desc)])
  @@index([brainId])
  @@map("node_attachments")
}

model NodeAttachmentChunk {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attachmentId String   @map("attachment_id") @db.Uuid
  nodeId       String   @map("node_id") @db.Uuid
  brainId      String   @map("brain_id") @db.Uuid
  chunkIndex   Int      @map("chunk_index")
  content      String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  attachment   NodeAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  node         Node           @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  brain        Brain          @relation(fields: [brainId], references: [id], onDelete: Cascade)

  @@unique([attachmentId, chunkIndex])
  @@index([brainId])
  @@index([nodeId])
  @@map("node_attachment_chunks")
}

enum UsageFeature {
  ai_document
  ai_agent
  web_search
  file_upload
  file_download
  attachment_extraction
}

model UsageRecord {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String        @map("organization_id") @db.Uuid
  userId            String?       @map("user_id") @db.Uuid
  brainId           String?       @map("brain_id") @db.Uuid
  nodeId            String?       @map("node_id") @db.Uuid
  feature           UsageFeature
  quantity          Int           @default(1)
  tokensPrompt      Int?          @map("tokens_prompt")
  tokensCompletion  Int?          @map("tokens_completion")
  tokensTotal       Int?          @map("tokens_total")
  bytesIn           BigInt?       @map("bytes_in")
  bytesOut          BigInt?       @map("bytes_out")
  estimatedCostUsd  Decimal?      @map("estimated_cost_usd") @db.Decimal(12, 6)
  metadata          Json?
  createdAt         DateTime      @default(now()) @map("created_at")

  // Relations
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  brain             Brain?        @relation(fields: [brainId], references: [id], onDelete: SetNull)
  node              Node?         @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([feature, createdAt])
  @@index([brainId, createdAt])
  @@index([userId, createdAt])
  @@map("usage_records")
}


